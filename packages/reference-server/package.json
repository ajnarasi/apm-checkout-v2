{
  "name": "@commercehub/reference-server",
  "version": "2.0.0-poc.0",
  "description": "Reference Express backend for Commerce Hub session creation, orders proxy, webhooks, and SSE relay",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@commercehub/node": "*",
    "@commercehub/shared-types": "*",
    "express": "^4.19.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.2.0",
    "pino": "^9.0.0",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.7.0",
    "vitest": "^2.0.0",
    "supertest": "^7.0.0",
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0"
  },
  "files": ["dist"]
}
