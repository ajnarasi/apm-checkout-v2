# Commerce Hub API
CH_BASE_URL=https://cert.api.firstdata.com
CH_API_KEY=your-sandbox-api-key
# POC mode — static access token. Refuses to boot if NODE_ENV=production.
CH_STATIC_ACCESS_TOKEN=your-sandbox-bearer-token

# Server
NODE_ENV=development
PORT=3848

# CORS allowlist (comma-separated). REQUIRED in production. No `*`.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Webhook signing secret (per-provider verification — see WEBHOOKS.md)
CH_WEBHOOK_SECRET=replace-me-with-real-secret

# Optional — multi-instance refusal guard
INSTANCE_COUNT=1

# Optional — Redis URL for v2.1 multi-instance event bus (NOT used in POC)
# REDIS_URL=redis://localhost:6379
