{
  "name": "@commercehub/node",
  "version": "2.0.0-poc.0",
  "description": "Server-side Commerce Hub Credentials API client — HMAC stub, static auth (POC), retry, circuit breaker, token cache, PII redaction",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "tag": "poc",
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@commercehub/shared-types": "*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.0.0",
    "nock": "^13.5.0"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "files": ["dist"]
}
