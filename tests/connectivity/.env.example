# Connectivity test runner credentials.
#
# Copy to `.env` and fill in. `.env` is gitignored — never commit secrets.
#
# Sandbox URLs are baked into run.sh; you only set credentials here.

# ───────────────────────────────────────────────────────────────────
# KLARNA — playground (NA region)
# Source: cardfree-sdk/backend-server/src/main/.../KlarnaPaymentRoutes.kt
# These are Fiserv-shared playground credentials.
# ───────────────────────────────────────────────────────────────────
KLARNA_USERNAME=
KLARNA_PASSWORD=

# ───────────────────────────────────────────────────────────────────
# CASH APP — sandbox (Network API)
# Source: cardfree-sdk/backend-server/src/main/.../Application.kt
# Fiserv-shared sandbox tenant.
# ───────────────────────────────────────────────────────────────────
CASHAPP_CLIENT_ID=
CASHAPP_API_KEY=
# Optional — overrides the cardfree-sdk default merchant
CASHAPP_MERCHANT_ID=MMI_1nk0ecoa69ilax9gno1lz6luh

# ───────────────────────────────────────────────────────────────────
# APPLE PAY
# .cer is in the v1 test-harness; .key is REQUIRED for merchant validation
# but currently MISSING. Provide the private key file path here.
# ───────────────────────────────────────────────────────────────────
APPLEPAY_CERT_PATH=/Users/ajnarasi/Documents/Work/Projects/APM/test-harness/certs/apple-pay-merchant.cer
APPLEPAY_KEY_PATH=
APPLEPAY_MERCHANT_ID=merchant.app.vercel.hottopic
APPLEPAY_DOMAIN=

# ───────────────────────────────────────────────────────────────────
# COMMERCE HUB — Fiserv sandbox (cert.api.firstdata.com)
# Used to test:
#   - The v2.1 reference server's /v2/sessions and /v2/orders/* routes
#   - Google Pay tokenization → CH /checkouts/v1/orders settlement
# REQUIRED FROM USER — not derivable from any on-disk source.
# ───────────────────────────────────────────────────────────────────
CH_BASE_URL=https://cert.api.firstdata.com
CH_API_KEY=
CH_API_SECRET=
CH_STATIC_ACCESS_TOKEN=
CH_MERCHANT_ID=
CH_TERMINAL_ID=
CH_STORE_ID=

# ───────────────────────────────────────────────────────────────────
# GOOGLE PAY
# Browser tokenization happens in the SDK — this section configures
# the test fixture used to forward a stub Google Pay tokenization
# payload to Commerce Hub. Real device tokens cannot be generated
# from a server-side test.
# ───────────────────────────────────────────────────────────────────
GOOGLEPAY_MERCHANT_ID=
GOOGLEPAY_GATEWAY=fiserv
GOOGLEPAY_GATEWAY_MERCHANT_ID=
